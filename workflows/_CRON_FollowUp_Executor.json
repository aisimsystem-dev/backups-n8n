    {
      "parameters": {
        "jsCode": "const ctx = $('PREPARE_CONTEXT').item.json;\nlet raw = $input.item.json.output || {};\n\nif (typeof raw === 'string') {\n  try {\n    raw = JSON.parse(raw.replace(/```json|```/g, '').trim());\n  } catch (e) {\n    raw = { full_user_profile: raw, summary_user_profile: '' };\n  }\n}\n\nconst full    = raw.full_user_profile    || JSON.stringify(ctx.user_profile) || '';\nconst summary = raw.summary_user_profile || '';\n\nconst esc = s => String(s).replace(/'/g, \"''\");\n\nreturn {\n  json: {\n    full_user_profile:    full,\n    summary_user_profile: summary,\n    user_id:              ctx.user_id,\n    contact_id:           ctx.contact_id,\n    account_id:           ctx.account_id,\n    base_url:             ctx.base_url,\n    user_token:           ctx.user_token,\n    save_profile_sql:     `UPDATE users SET user_profile = '${esc(JSON.stringify({ full: full, summary: summary }))}'::jsonb, updated_at = NOW() WHERE user_id = '${esc(ctx.user_id)}';`\n  }\n};"
      },
