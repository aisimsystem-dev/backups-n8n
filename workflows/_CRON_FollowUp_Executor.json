    {
      "parameters": {
        "jsCode": "const raw = String($input.item.json.output || '');\n\nconst clean = raw\n  .replace(/Calling\\s+\\w[\\w_]*\\s+with[\\s\\S]*?\\}/gi, '')\n  .replace(/\\{\\s*\"[^\"]+\"\\s*:[\\s\\S]*?\\}/g, '')\n  .replace(/```[\\s\\S]*?```/g, '')\n  .replace(/^(Tool|Function|Action)\\s*:.*$/gim, '')\n  .replace(/\\*{1,3}([^*]+)\\*{1,3}/g, '$1')\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .trim();\n\nreturn {\n  json: {\n    message: clean || 'Olá! Passei para ver se posso ajudar em algo. 😊'\n  }\n};"
      },
