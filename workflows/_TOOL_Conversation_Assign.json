      "notes": "Recebe: unique_id (string), assignee_id (number), note (string, opcional)"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst parts = (input.unique_id || '').split('-');\n\nif (parts.length < 3) {\n  return { json: { success: false, error: 'unique_id inválido: ' + input.unique_id } };\n}\n\nconst note = (input.note || '').trim();\n\nreturn {\n  json: {\n    account_id:      parseInt(parts[0]),\n    inbox_id:        parseInt(parts[1]),\n    conversation_id: parseInt(parts[2]),\n    assignee_id:     parseInt(input.assignee_id),\n    note:            note,\n    unique_id:       input.unique_id\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "bd7cfb5b-9af6-4633-81c5-739194948295",
      "name": "Parse_IDs",
      "notes": "Extrai account_id, inbox_id, conversation_id do unique_id. Preserva note."
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT base_url, user_token FROM system_projects WHERE account_id = {{ $json.account_id }} AND is_active = true LIMIT 1;",
