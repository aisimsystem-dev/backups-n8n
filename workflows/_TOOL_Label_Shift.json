      "notes": "Busca labels atuais da conversa no Chatwoot"
    },
    {
      "parameters": {
        "jsCode": "let labels       = $json.body?.payload || [];\nconst remove     = $('Parse_IDs').item.json.remove_label;\nconst add        = $('Parse_IDs').item.json.add_label;\nconst base_url   = $('Get_Config').item.json.base_url;\nconst user_token = $('Get_Config').item.json.user_token;\nconst account_id      = $('Parse_IDs').item.json.account_id;\nconst conversation_id = $('Parse_IDs').item.json.conversation_id;\n\nif (remove) labels = labels.filter(l => l !== remove);\nif (add && !labels.includes(add)) labels.push(add);\n\nreturn {\n  json: { labels, base_url, user_token, account_id, conversation_id }\n};"
      },
      "type": "n8n-nodes-base.code",
